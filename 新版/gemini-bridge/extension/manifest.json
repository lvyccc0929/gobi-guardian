{
  "manifest_version": 3,
  "name": "Gemini Bridge",
  "version": "0.0.0",
  "description": "Sync Gemini auth cookies to the local Gemini Bridge server.",
  "permissions": ["cookies", "alarms", "storage"],
  "host_permissions": [
    "https://*.google.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"],
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "gemini-bridge@local.dev",
      "strict_min_version": "115.0"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gemini Bridge",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_ui": {
    "page": "popup.html",
    "open_in_tab": false
  }
}
