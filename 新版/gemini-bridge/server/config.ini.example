# --- Browser Settings ---
# Supported: firefox, librewolf, chrome, chromium, brave, edge, opera,
# opera_gx, vivaldi. Used only for the local headless fallback when no
# extension is loaded and `GEMINI_COOKIE_*` env vars are unset. Firefox is
# recommended — Chromium-family cookies are device-bound on 2025+ Chrome and
# trigger silent aborts on Pro models.
[Browser]
name = firefox

# --- Gemini Model Configuration ---
# default_model is informational — clients pick per request.
# IDs: gemini-3-pro, gemini-3-flash, gemini-3-flash-thinking, and -plus/-advanced variants.
# gem_id (optional): pre-select a Gem (custom system prompt). Empty = none. Popup can override at runtime.
[Gemini]
default_model = gemini-3-flash
gem_id =

# --- Gemini Cookies ---
# Paste manually or let the Chrome extension push them.
[Cookies]
gemini_cookie_1psid =
gemini_cookie_1psidts =

# --- Proxy Configuration ---
# Example: http_proxy = http://127.0.0.1:8080
[Proxy]
http_proxy =
