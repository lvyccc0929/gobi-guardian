# Gemini Bridge — environment variables.
# Copy to `.env` (gitignored). Auto-sourced by start.sh and Docker Compose.
#
# Precedence: env > config.conf > extension/popup runtime.
# Values here override config.conf at boot. Popup Gem changes live in memory until restart.

# --- Server ---

GEMINI_BRIDGE_PORT=6969

# Verbose debug logs → console + /tmp/gemini-bridge-debug.log.
# Also implies GEMINI_BRIDGE_DUMP_PROMPTS=1.
# GEMINI_BRIDGE_DEBUG=1

# Expose /docs, /redoc and /openapi.json (off by default — keeps the internal
# admin surface out of reach of any local process or curious user).
# GEMINI_BRIDGE_ENABLE_DOCS=1

# Dump every rendered prompt to server/logs/prompts/<ts>_<reqid>.txt.
# Off by default — prompts can carry secrets pasted by the user.
# GEMINI_BRIDGE_DUMP_PROMPTS=1

# Override the silent-abort guardrail (~100 KB on gemini-3-pro-advanced).
# Only touch this if you've measured a different empirical threshold.
# GEMINI_BRIDGE_MAX_PROMPT_CHARS=100000

# --- Gemini auth (headless / no-extension) ---
# DevTools → Application → Cookies → gemini.google.com.
# If unset: [Cookies] in config.conf, then browser_cookie3 (Firefox-family or
# any Chromium-family local profile — see [Browser].name in config.conf).
# GEMINI_COOKIE_1PSID=g.a000…
# GEMINI_COOKIE_1PSIDTS=sidts-…

# Multi-account: which `/u/N` Google account. Default 0.
# GEMINI_BRIDGE_ACCOUNT_INDEX=0

# Pre-select a Gem. ID = last path segment of the Gem URL,
# e.g. https://gemini.google.com/u/0/gem/eb0eb9162487 → eb0eb9162487.
# GEMINI_BRIDGE_GEM_ID=
